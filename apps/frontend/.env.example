# Frontend Vite — variables de entorno
# Copiar a .env.local para desarrollo local.
# En Railway: estas vars se pasan como BUILD ARGS en el Dockerfile.frontend.
# Las vars con prefijo VITE_ quedan horneadas en el bundle en tiempo de build.

# ── API URL ──────────────────────────────────────────────────────────────────
# DEV: apuntar al gateway local
# RAILWAY: dejar VACÍO → el frontend usa URLs relativas (/api/...) y nginx proxea.
VITE_API_BASE_URL=http://localhost:8080

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME=CRM La Internacional

# ── Modo mock ─────────────────────────────────────────────────────────────────
# true  = frontend funciona sin backend (datos mockeados en localStorage)
# false = frontend hace llamadas reales al backend
VITE_USE_MOCKS=true

# ── Polling intervals (ms) ────────────────────────────────────────────────────
VITE_POLL_INBOX_MS=15000
VITE_POLL_NOTIFICATIONS_MS=30000
VITE_POLL_CHAT_MS=5000

# ── Meta WhatsApp (frontend) ──────────────────────────────────────────────────
# Estas se usan en el proxy de Vite (dev) y en los stores del frontend.
# NUNCA incluir META_ACCESS_TOKEN acá (usar .env.local o Railway Variables).
VITE_META_WABA_ID=
VITE_META_PHONE_NUMBER_ID=
VITE_META_TEST_PHONE=

# ── Meta token (SOLO para desarrollo local, NO commitear) ─────────────────────
# El proxy de Vite usa este token para las llamadas a graph.facebook.com.
# En Railway NO se necesita: el backend maneja Meta directamente.
# META_ACCESS_TOKEN=
