# Backend NestJS — variables de entorno
# Copiar a .env.local para desarrollo local
# En Railway: configurar directamente en el Dashboard → Variables

# ── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Puertos (servicios internos) ─────────────────────────────────────────────
# En Railway todos corren en el mismo container; solo GATEWAY_PORT es externo.
# Railway inyecta PORT automáticamente al gateway.
GATEWAY_PORT=8080
AUTH_PORT=3001
CRM_CORE_PORT=3002
MESSAGING_PORT=3003
BROADCASTS_PORT=3004
POSTSALE_PORT=3005
ANALYTICS_PORT=3006
INTEGRATION_PORT=3007

# ── URLs internas entre servicios ────────────────────────────────────────────
# En Railway (container único), todos los servicios se comunican via localhost.
AUTH_URL=http://localhost:3001
CRM_CORE_URL=http://localhost:3002
MESSAGING_URL=http://localhost:3003
BROADCASTS_URL=http://localhost:3004
POSTSALE_URL=http://localhost:3005
ANALYTICS_URL=http://localhost:3006
INTEGRATION_URL=http://localhost:3007

# ── Base de datos ────────────────────────────────────────────────────────────
# Railway auto-inyecta DATABASE_URL al agregar el add-on de PostgreSQL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lid
POSTSALE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lid_postsale

# ── Autenticación ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ── WhatsApp Cloud API (Meta) ────────────────────────────────────────────────
# IMPORTANTE: nunca commitear valores reales. Cargar solo en Railway Dashboard.
META_APP_ID=
META_APP_SECRET=
META_PHONE_NUMBER_ID=
META_BUSINESS_ACCOUNT_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_GRAPH_VERSION=v25.0

# ── Sistema externo ──────────────────────────────────────────────────────────
EXTERNAL_SYSTEM_BASE_URL=
EXTERNAL_SYSTEM_API_KEY=
EXTERNAL_SYSTEM_MOCK=true
