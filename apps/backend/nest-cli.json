{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "services/gateway/src",
  "monorepo": true,
  "root": "services/gateway",
  "compilerOptions": {
    "webpack": true,
    "tsConfigPath": "services/gateway/tsconfig.app.json"
  },
  "projects": {
    "gateway": {
      "type": "application",
      "root": "services/gateway",
      "entryFile": "main",
      "sourceRoot": "services/gateway/src",
      "compilerOptions": { "tsConfigPath": "services/gateway/tsconfig.app.json" }
    },
    "auth-service": {
      "type": "application",
      "root": "services/auth",
      "entryFile": "main",
      "sourceRoot": "services/auth/src",
      "compilerOptions": { "tsConfigPath": "services/auth/tsconfig.app.json" }
    },
    "crm-core-service": {
      "type": "application",
      "root": "services/crm-core",
      "entryFile": "main",
      "sourceRoot": "services/crm-core/src",
      "compilerOptions": { "tsConfigPath": "services/crm-core/tsconfig.app.json" }
    },
    "messaging-service": {
      "type": "application",
      "root": "services/messaging",
      "entryFile": "main",
      "sourceRoot": "services/messaging/src",
      "compilerOptions": { "tsConfigPath": "services/messaging/tsconfig.app.json" }
    },
    "broadcasts-service": {
      "type": "application",
      "root": "services/broadcasts",
      "entryFile": "main",
      "sourceRoot": "services/broadcasts/src",
      "compilerOptions": { "tsConfigPath": "services/broadcasts/tsconfig.app.json" }
    },
    "postsale-service": {
      "type": "application",
      "root": "services/postsale",
      "entryFile": "main",
      "sourceRoot": "services/postsale/src",
      "compilerOptions": { "tsConfigPath": "services/postsale/tsconfig.app.json" }
    },
    "analytics-service": {
      "type": "application",
      "root": "services/analytics",
      "entryFile": "main",
      "sourceRoot": "services/analytics/src",
      "compilerOptions": { "tsConfigPath": "services/analytics/tsconfig.app.json" }
    },
    "integration-service": {
      "type": "application",
      "root": "services/integration",
      "entryFile": "main",
      "sourceRoot": "services/integration/src",
      "compilerOptions": { "tsConfigPath": "services/integration/tsconfig.app.json" }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": { "tsConfigPath": "libs/common/tsconfig.lib.json" }
    }
  }
}
