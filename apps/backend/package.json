{
  "name": "@lid/backend",
  "version": "0.1.0",
  "private": true,
  "description": "CRM backend. NestJS monorepo: gateway + 7 servicios.",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"services/**/*.ts\"",
    "start:gateway": "nest start gateway --watch",
    "start:auth": "nest start auth-service --watch",
    "start:crm-core": "nest start crm-core-service --watch",
    "start:messaging": "nest start messaging-service --watch",
    "start:broadcasts": "nest start broadcasts-service --watch",
    "start:postsale": "nest start postsale-service --watch",
    "start:analytics": "nest start analytics-service --watch",
    "start:integration": "nest start integration-service --watch"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
