# ============================================================================
# Frontend (Vite)
# ============================================================================
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_NAME=CRM La Internacional
VITE_POLL_INBOX_MS=15000
VITE_POLL_NOTIFICATIONS_MS=30000
VITE_POLL_CHAT_MS=5000
VITE_USE_MOCKS=true
VITE_META_WABA_ID=
VITE_META_PHONE_NUMBER_ID=
VITE_META_TEST_PHONE=

# ============================================================================
# Backend (NestJS - Monorepo)
# ============================================================================
NODE_ENV=development

# Ports for each service (used when running locally)
GATEWAY_PORT=8080
AUTH_PORT=3001
CRM_CORE_PORT=3002
MESSAGING_PORT=3003
BROADCASTS_PORT=3004
POSTSALE_PORT=3005
ANALYTICS_PORT=3006
INTEGRATION_PORT=3007

# Internal service URLs
# LOCAL: http://localhost:{PORT}
# RAILWAY (todos en mismo container): http://localhost:{PORT}
AUTH_URL=http://localhost:3001
CRM_CORE_URL=http://localhost:3002
MESSAGING_URL=http://localhost:3003
BROADCASTS_URL=http://localhost:3004
POSTSALE_URL=http://localhost:3005
ANALYTICS_URL=http://localhost:3006
INTEGRATION_URL=http://localhost:3007

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lid
POSTSALE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lid_postsale

# ============================================================================
# Authentication
# ============================================================================
JWT_SECRET=change-me-in-production-use-strong-random-string
JWT_EXPIRES_IN=7d

# ============================================================================
# WhatsApp Cloud API (Meta)
# ============================================================================
META_APP_ID=
META_APP_SECRET=
META_PHONE_NUMBER_ID=
META_BUSINESS_ACCOUNT_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_GRAPH_VERSION=v25.0

# ============================================================================
# External System Integration
# ============================================================================
EXTERNAL_SYSTEM_BASE_URL=
EXTERNAL_SYSTEM_API_KEY=
EXTERNAL_SYSTEM_MOCK=true
