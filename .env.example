# ============================================================================
# Frontend (Vite)
# ============================================================================
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_NAME=CRM La Internacional
VITE_POLL_INBOX_MS=15000
VITE_POLL_NOTIFICATIONS_MS=30000
VITE_POLL_CHAT_MS=5000
VITE_USE_MOCKS=true

# ============================================================================
# Backend (NestJS - Monorepo)
# ============================================================================
NODE_ENV=development

# Ports for each service (used when running locally)
GATEWAY_PORT=8080
AUTH_PORT=3001
CRM_CORE_PORT=3002
MESSAGING_PORT=3003
BROADCASTS_PORT=3004
POSTSALE_PORT=3005
ANALYTICS_PORT=3006
INTEGRATION_PORT=3007

# Internal service URLs
# LOCAL: http://localhost:{PORT}
# RAILWAY/DOCKER: http://{service-name}.railway.internal:{PORT}
AUTH_URL=http://localhost:3001
CRM_CORE_URL=http://localhost:3002
MESSAGING_URL=http://localhost:3003
BROADCASTS_URL=http://localhost:3004
POSTSALE_URL=http://localhost:3005
ANALYTICS_URL=http://localhost:3006
INTEGRATION_URL=http://localhost:3007

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
# Main database (CRM core, messaging, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lid

# Postsale database (separate for scale)
POSTSALE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lid_postsale

# ============================================================================
# Authentication
# ============================================================================
JWT_SECRET=change-me-in-production-use-strong-random-string
JWT_EXPIRES_IN=7d

# ============================================================================
# WhatsApp Cloud API (Meta)
# ============================================================================
# CRITICAL: All Meta credentials MUST be set as environment variables,
# NEVER in version control. Railway/Docker will use these.

# App ID (numeric, visible in Meta Business Console)
META_APP_ID=

# App Secret (keep secure, for server-to-server)
META_APP_SECRET=

# WhatsApp Phone Number ID (found in Phone Numbers settings)
META_PHONE_NUMBER_ID=

# Business Account ID (WABA ID)
META_BUSINESS_ACCOUNT_ID=

# Access Token (primary - comes from Meta)
# This is the main token used for all Graph API calls.
# Rotate every ~60 days. Keep in environment variables only.
META_ACCESS_TOKEN=

# Verify Token (for webhook verification during setup)
# Generate a secure random string for webhook verification
META_VERIFY_TOKEN=

# Graph API version (update as needed)
META_GRAPH_VERSION=v25.0

# ============================================================================
# External System Integration
# ============================================================================
# Base URL of existing system (for integration-service)
EXTERNAL_SYSTEM_BASE_URL=

# API key for external system authentication
EXTERNAL_SYSTEM_API_KEY=

# Use mock responses (true for dev, false for production)
EXTERNAL_SYSTEM_MOCK=true
